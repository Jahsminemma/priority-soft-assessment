generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum ShiftStatus {
  DRAFT
  PUBLISHED
}

enum ScheduleWeekStatus {
  DRAFT
  PUBLISHED
}

enum AssignmentStatus {
  ASSIGNED
  PROPOSED
}

enum CoverageRequestType {
  SWAP
  DROP
}

enum CoverageRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  MANAGER_APPROVED
  CANCELLED
  EXPIRED
}

/** DROP only: OPEN = short-fuse broadcast, first claim final; DIRECTED = managers assign, not shown to all staff. */
enum CalloutMode {
  OPEN
  DIRECTED
}

enum AvailabilityExceptionType {
  UNAVAILABLE
  AVAILABLE_OVERRIDE
}

enum NotificationChannel {
  IN_APP
  EMAIL_SIMULATED
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  passwordHash       String
  name               String
  role               UserRole
  desiredHoursWeekly Float?
  /** Optional wage for labor / OT projections; falls back to location default. */
  hourlyRate         Float?
  notificationPrefs  Json     @default("{}")
  createdAt          DateTime @default(now())

  managerLocations ManagerLocation[]
  staffSkills        StaffSkill[]
  certifications     StaffCertification[]
  availabilityRules  AvailabilityRule[]
  availabilityExceptions AvailabilityException[]
  shiftAssignments   ShiftAssignment[] @relation("StaffAssignments")
  createdShifts      Shift[] @relation("ShiftCreator")
  coverageRequestsAsRequester CoverageRequest[] @relation("Requester")
  coverageRequestsAsTarget    CoverageRequest[] @relation("Target")
  notifications      Notification[]
  auditLogs          AuditLog[] @relation("Actor")
  clockSessions      ClockSession[]
  clockInVerificationCodesAsStaff ClockInVerificationCode[] @relation("ClockVerificationStaff")
  clockVerificationCodesVerified  ClockInVerificationCode[] @relation("ClockVerificationVerifier")
  registrationInvitesCreated RegistrationInvite[] @relation("RegistrationInvitesCreated")
}

model RegistrationInvite {
  id                 String    @id @default(uuid())
  tokenHash          String    @unique
  email              String
  name               String
  role               UserRole
  desiredHoursWeekly Float?
  managerLocationIds Json?
  /** When role is STAFF: skill UUIDs to assign on registration. */
  staffSkillIds      Json?
  /** When role is STAFF: location UUIDs where they are certified to work. */
  staffLocationIds   Json?
  expiresAt          DateTime
  createdById        String
  createdAt          DateTime  @default(now())
  consumedAt         DateTime?

  createdBy User @relation("RegistrationInvitesCreated", fields: [createdById], references: [id], onDelete: Cascade)
}

model ManagerLocation {
  userId     String
  locationId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([userId, locationId])
}

model Location {
  id       String @id @default(uuid())
  name     String
  tzIana   String
  /** Default hourly wage for OT/labor projections when staff has no override. */
  defaultHourlyRate Float?

  managerLocations ManagerLocation[]
  shifts           Shift[]
  certifications   StaffCertification[]
  scheduleWeeks    ScheduleWeek[]
}

model Skill {
  id   String @id @default(uuid())
  name String @unique

  staffSkills StaffSkill[]
  shifts      Shift[]
}

model StaffSkill {
  userId  String
  skillId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
}

model StaffCertification {
  userId     String
  locationId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([userId, locationId])
}

model AvailabilityRule {
  id              String   @id @default(uuid())
  userId          String
  dayOfWeek       Int
  startLocalTime  String
  endLocalTime    String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvailabilityException {
  id         String                    @id @default(uuid())
  userId     String
  startAtUtc DateTime
  endAtUtc   DateTime
  type       AvailabilityExceptionType
  /** IANA zone used when the staff entered start/end (matches shift wall times at that site). */
  tzIana     String?
  user       User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScheduleWeek {
  id               String             @id @default(uuid())
  locationId       String
  weekStartDateLocal String
  status           ScheduleWeekStatus @default(DRAFT)
  cutoffHours      Int                @default(48)
  /** Bumped when shifts or assignments change after the week row exists (republish needed when published). */
  scheduleContentRevision  Int @default(0)
  /** Snapshot of scheduleContentRevision at last successful publish. */
  publishedContentRevision Int @default(0)
  location         Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, weekStartDateLocal])
}

model Shift {
  id               String      @id @default(uuid())
  locationId       String
  startAtUtc       DateTime
  endAtUtc         DateTime
  requiredSkillId  String
  headcount        Int
  isPremium        Boolean     @default(false)
  status           ShiftStatus @default(DRAFT)
  weekKey          String
  createdById      String?
  location         Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  requiredSkill    Skill       @relation(fields: [requiredSkillId], references: [id])
  createdBy        User?       @relation("ShiftCreator", fields: [createdById], references: [id])
  assignments              ShiftAssignment[]
  coverageRequestsPrimary  CoverageRequest[] @relation("CoveragePrimaryShift")
  coverageRequestsSecond   CoverageRequest[] @relation("CoverageSecondShift")
  clockSessions            ClockSession[]
  clockInVerificationCodes ClockInVerificationCode[]
}

model ShiftAssignment {
  id          String           @id @default(uuid())
  shiftId     String
  staffUserId String
  status      AssignmentStatus @default(ASSIGNED)
  createdAt   DateTime         @default(now())
  shift       Shift            @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  staff       User             @relation("StaffAssignments", fields: [staffUserId], references: [id], onDelete: Cascade)

  @@unique([shiftId, staffUserId])
  @@index([staffUserId])
}

model CoverageRequest {
  id            String                @id @default(uuid())
  type          CoverageRequestType
  /** Requester's shift (the shift they are giving up in a swap, or the only shift in a handoff/drop). */
  shiftId       String
  /** For a two-person shift swap: the target's shift (Staff B's shift). Null = single handoff swap (A gives shift to B only). */
  secondShiftId String?
  requesterId   String
  targetId      String?
  status        CoverageRequestStatus @default(PENDING)
  createdAt     DateTime              @default(now())
  expiresAt     DateTime?
  /** DROP only: null for SWAP. */
  calloutMode   CalloutMode?
  shift         Shift                 @relation("CoveragePrimaryShift", fields: [shiftId], references: [id], onDelete: Cascade)
  secondShift   Shift?                @relation("CoverageSecondShift", fields: [secondShiftId], references: [id], onDelete: Cascade)
  requester     User                  @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  target        User?                 @relation("Target", fields: [targetId], references: [id], onDelete: SetNull)
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  actorUserId String
  entityType String
  entityId   String
  action     String
  beforeJson Json?
  afterJson  Json?
  createdAt  DateTime @default(now())
  actor      User     @relation("Actor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
}

model ClockSession {
  id             String    @id @default(uuid())
  staffUserId    String
  shiftId        String?
  clockInAtUtc   DateTime
  clockOutAtUtc  DateTime?
  staff          User      @relation(fields: [staffUserId], references: [id], onDelete: Cascade)
  shift          Shift?    @relation(fields: [shiftId], references: [id], onDelete: SetNull)
}

/** Short-lived code staff shows to a manager to verify clock-in. */
model ClockInVerificationCode {
  id               String    @id @default(uuid())
  code             String    @unique
  staffUserId      String
  shiftId          String
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  consumedAt       DateTime?
  verifiedByUserId String?
  staff            User      @relation("ClockVerificationStaff", fields: [staffUserId], references: [id], onDelete: Cascade)
  verifiedBy       User?     @relation("ClockVerificationVerifier", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  shift            Shift     @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([staffUserId, shiftId])
}

model IdempotencyKey {
  key       String   @id
  resultJson Json
  createdAt DateTime @default(now())
}
